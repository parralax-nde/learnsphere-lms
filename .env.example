# Google OAuth credentials (register your app at https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Callback URL registered in Google Cloud Console
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# JWT secret (use a long, random string in production)
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=1h

# Frontend URL to redirect after successful login
FRONTEND_URL=http://localhost:5173

# Server port
PORT=3000
NODE_ENV=development
