# Application
NODE_ENV=development
PORT=3000

# Database (SQLite by default; swap to postgres:// for production)
DATABASE_URL=sqlite:./learnsphere.db

# JWT
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Password Reset Token expiry (minutes)
PASSWORD_RESET_TOKEN_EXPIRES_MIN=60

# Client URL (used to build reset links)
CLIENT_URL=http://localhost:3000

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@example.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=LearnSphere <no-reply@example.com>

# Rate limiting – forgot-password endpoint
FORGOT_PASSWORD_RATE_LIMIT_WINDOW_MIN=15
FORGOT_PASSWORD_RATE_LIMIT_MAX=5
