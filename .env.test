# LearnSphere LMS – local env (NOT committed; see .env.example)
NODE_ENV=test
PORT=3000
DATABASE_URL=sqlite::memory:
JWT_SECRET=test_jwt_secret_do_not_use_in_production
JWT_EXPIRES_IN=7d
PASSWORD_RESET_TOKEN_EXPIRES_MIN=60
CLIENT_URL=http://localhost:3000
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=test@example.com
SMTP_PASS=testpass
EMAIL_FROM=LearnSphere <no-reply@example.com>
FORGOT_PASSWORD_RATE_LIMIT_WINDOW_MIN=15
FORGOT_PASSWORD_RATE_LIMIT_MAX=5
