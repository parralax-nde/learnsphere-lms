# ──────────────────────────────────────────────────────────────────────────────
# LearnSphere LMS – Backend environment variables
# Copy this file to .env and fill in the values before running the server.
# ──────────────────────────────────────────────────────────────────────────────

# ---------------------------------------------------------------------------
# Security – REQUIRED in production
# ---------------------------------------------------------------------------
# Generate a strong secret with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# ---------------------------------------------------------------------------
# JWT / Session settings
# ---------------------------------------------------------------------------
# How long (in minutes) an access token is valid.  Keep this short.
ACCESS_TOKEN_EXPIRE_MINUTES=30

# How long (in days) a refresh token is valid.
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# SQLite (default – suitable for local development):
DATABASE_URL=sqlite:///./learnsphere.db

# PostgreSQL example (recommended for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/learnsphere

# ---------------------------------------------------------------------------
# CORS / Cookie
# ---------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173

# Set to "true" in production (requires HTTPS).
COOKIE_SECURE=false

# "lax" is appropriate for most SPAs; use "none" only with COOKIE_SECURE=true.
COOKIE_SAMESITE=lax
