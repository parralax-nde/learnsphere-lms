DATABASE_URL="file:./dev.db"
JWT_SECRET="change-this-to-a-random-secret-in-production"
PORT=3001

# Email configuration (use a real SMTP provider in production)
# For development, set EMAIL_ENABLED=false to skip sending emails (tokens logged to console)
EMAIL_ENABLED=false
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password
EMAIL_FROM="LearnSphere <noreply@example.com>"

# The base URL of the frontend application (used in email verification links)
FRONTEND_URL=http://localhost:5173
