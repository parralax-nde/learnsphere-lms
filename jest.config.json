{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>/src"],
  "testMatch": ["**/__tests__/**/*.test.ts"],
  "setupFiles": ["<rootDir>/src/__tests__/setup.ts"],
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/src/$1"
  },
  "transform": {
    "^.+\\.tsx?$": ["ts-jest", {
      "tsconfig": {
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true
      }
    }]
  }
}
