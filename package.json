{
  "name": "learnsphere-lms",
  "version": "1.0.0",
  "description": "An online learning management system designed to host and deliver educational courses, including interactive lessons, quizzes, and progress tracking. It provides comprehensive dashboards for students and instructors, enabling course enrollment, content creation, performance analytics, and secure payment processing for a medium-business scale.",
  "main": "src/server.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "start": "node src/server.js",
    "test": "NODE_ENV=test jest --runInBand --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "setupFiles": []
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/parralax-nde/learnsphere-lms.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/parralax-nde/learnsphere-lms/issues"
  },
  "homepage": "https://github.com/parralax-nde/learnsphere-lms#readme",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^7.0.11",
    "sequelize": "^6.37.8",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  }
}
